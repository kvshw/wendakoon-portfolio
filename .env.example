# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/admin
ADMIN_EMAILS=you@example.com

# Supabase
SUPABASE_URL=https://drcautjhivgdaioqurss.supabase.co/
SUPABASE_SERVICE_ROLE_KEY=
# If the DB password contains @, encode it as %40 in the URL.
# Prefer the Supabase pooler for Next.js (prepare: false in lib/db/drizzle.ts):
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# Direct connection (migrations / local psql only if db.* resolves):
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Anthropic
ANTHROPIC_API_KEY=

# Optional: AI cover images (DALL-E 3). Without this, branded SVG covers are generated instead.
OPENAI_API_KEY=
# Set to "rendered" to always use high-res branded PNG covers even when OPENAI_API_KEY is set.
# CONTENT_COVER_PROVIDER=rendered

# Cron
CRON_SECRET=

# Resend
RESEND_API_KEY=
NOTIFY_TO_EMAIL=kaveebhashiofficial@gmail.com
NOTIFY_FROM_EMAIL=onboarding@resend.dev

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

